{
  "schema": "readerlab.contract-validator-schema.v1",
  "contract_schema": "readerlab.global-map.v1",
  "description": "ReaderLab v0.4 global map fact-layer contract. Markdown is only a display layer.",
  "required_top_level": [
    "schema",
    "material",
    "source_scope",
    "global_map",
    "confidence",
    "review_items",
    "machine_status",
    "human_status",
    "display"
  ],
  "required_fields": {
    "material": ["id", "title", "type"],
    "source_scope": ["coverage_status", "items", "coverage_note"],
    "confidence": ["level", "basis"],
    "display": ["markdown_path", "relationship"],
    "global_map": [
      "core_questions",
      "structure_mainline",
      "unit_relationships",
      "concept_method_case_relationships",
      "reading_routes"
    ]
  },
  "required_item_fields": {
    "source_scope.items": ["id", "source_ref", "range", "role"],
    "review_items": ["id", "question", "status"]
  },
  "non_empty": [
    "source_scope.items",
    "confidence.basis",
    "review_items",
    "global_map.core_questions",
    "global_map.structure_mainline",
    "global_map.reading_routes"
  ],
  "allowed_values": {
    "source_scope.coverage_status": ["full", "partial", "sample", "unknown"],
    "confidence.level": ["high", "medium", "low"],
    "machine_status": ["draft", "ready", "needs_review", "blocked"],
    "human_status": ["pending", "accepted", "rejected", "not_required"],
    "display.relationship": ["renders_from_contract", "manual_companion", "not_rendered"]
  }
}
